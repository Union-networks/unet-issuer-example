# Optional in production: SDK packages default to https://issuer.egress.live.
# Set this only for local/staging trust-plane environments.
# NEXT_PUBLIC_UNET_ISSUER_BASE_URL=https://issuer.egress.live

NEXT_PUBLIC_UNET_SERVICE_ID=unet-issuer-example
NEXT_PUBLIC_UNET_ORIGIN=https://your-vercel-domain.example
UNET_WEB_LOGIN_ASSERTION_SECRET=replace-with-trust-plane-secret

# Domain proof from the U-net dashboard. Keep these server-side only.
UNET_PROVIDER_CLAIM_ID=claim_from_dashboard
UNET_PROVIDER_CLAIM_CHALLENGE=challenge_from_dashboard
UNET_PROVIDER_CLAIM_TOKEN=raw_claim_token_from_dashboard

# Provider/issuer server credentials. Never expose these to browser bundles.
UNET_PROVIDER_API_KEY=optional-provider-key
UNET_ISSUER_ID=issuer:unet-issuer-example
UNET_ISSUER_KEY_ID=issuer:unet-issuer-example#main
UNET_ISSUER_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
UNET_ISSUER_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
